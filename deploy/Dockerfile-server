# First stage: Build Python dependencies
FROM thanhlcm90/xiaozhi-server-base AS builder

WORKDIR /app

# Configure pip to use Aliyun mirror and set timeout and retries
RUN pip config set global.timeout 120 && \
    pip config set install.retries 5

COPY main/xiaozhi-server/requirements.txt .

# Install Python dependencies, use parallel downloading
RUN pip install -r requirements.txt --default-timeout=120 --retries 5

# Second stage: Production image
FROM python:3.10-slim

WORKDIR /opt/xiaozhi-esp32-server

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends libopus0 ffmpeg && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Copy Python packages and frontend build artifacts from builder stage
COPY --from=builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=builder /usr/local/bin/mcp-proxy /usr/local/bin/mcp-proxy

# Copy application code
COPY main/xiaozhi-server .

# Start application
CMD ["python", "app.py"]